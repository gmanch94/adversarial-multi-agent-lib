          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 8,
      "title": "Budget — tokens in/out + USD spent",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {"expr": "sum by (workflow) (durable_budget_tokens_in)", "legendFormat": "tokens_in {{workflow}}", "refId": "A"},
        {"expr": "sum by (workflow) (durable_budget_tokens_out)", "legendFormat": "tokens_out {{workflow}}", "refId": "B"},
        {"expr": "sum by (workflow) (durable_budget_usd_spent)", "legendFormat": "usd_spent {{workflow}}", "refId": "C"}
      ],
      "fieldConfig": {"defaults": {"unit": "short"}, "overrides": []},
