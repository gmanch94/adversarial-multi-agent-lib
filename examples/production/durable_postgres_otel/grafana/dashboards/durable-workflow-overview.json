  "liveNow": false,
  "panels": [
    {
      "id": 1,
      "title": "Workflow starts per minute (by workflow)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (workflow) (rate(durable_workflow_start_total[1m]))",
          "legendFormat": "{{workflow}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 2,
      "title": "Pause rate per workflow per reason",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (workflow, pause_reason) (rate(durable_workflow_pause_total[5m]))",
          "legendFormat": "{{workflow}} / {{pause_reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 3,
      "title": "Round latency p50/p95/p99 (seconds)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le, workflow) (rate(durable_round_latency_seconds_bucket[5m])))",
          "legendFormat": "p50 {{workflow}}",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le, workflow) (rate(durable_round_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{workflow}}",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le, workflow) (rate(durable_round_latency_seconds_bucket[5m])))",
          "legendFormat": "p99 {{workflow}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 4,
      "title": "Lock acquire failures per minute (by phase)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (phase) (rate(durable_lock_acquire_failed_total[1m]))",
          "legendFormat": "{{phase}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "multi"}}
    },
    {
      "id": 5,
      "title": "Lock acquire latency p95 (seconds, by phase)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, phase) (rate(durable_lock_acquire_latency_seconds_bucket[5m])))",
          "legendFormat": "p95 {{phase}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}, "overrides": []},
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 6,
      "title": "Lock pool saturation (gauge, by pool)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "durable_lock_pool_saturation",
          "legendFormat": "{{pool}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 0.7}, {"color": "red", "value": 0.85}]}
        },
        "overrides": []
      },
      "options": {"legend": {"displayMode": "list", "placement": "bottom"}, "tooltip": {"mode": "single"}}
    },
    {
      "id": 7,
      "title": "Cipher decrypt failure rate (by backend / error_class)",
