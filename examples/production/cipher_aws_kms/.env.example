# Copy to .env (gitignored) and fill real values.

# AWS KMS — operator MUST supply CMK alias/ARN.
AWS_KMS_CMK_ALIAS=alias/durable-checkpoints-payload-dek-wrapper
AWS_REGION=us-east-1

# IMDSv2 hardening (D-CIPHER-AWS-9): daemon refuses to start if v1 fallback
# is enabled in the container. Set this explicitly when running on EC2/ECS.
AWS_EC2_METADATA_V1_DISABLED=true

# Postgres — same shape as durable_postgres .env.example.
# A8-H-01: operator MUST set this with full password.
POSTGRES_DSN=postgresql://daemon:CHANGEME@postgres:5432/durable

# Model API keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Optional tuning
MAX_CONCURRENT_RUNS=20
POLL_INTERVAL=60
MAX_TOKENS_IN=2000000
MAX_TOKENS_OUT=500000
MAX_USD=50.0

# Cipher selection: "fernet", "gcp_kms", or "aws_kms".
CIPHER_BACKEND=aws_kms

# DEK cache (aws_kms only). TTL >= 3 * POLL_INTERVAL recommended.
DEK_CACHE_SIZE=1024
DEK_CACHE_TTL_SECONDS=300

# Tier 2.1d / SCALE-1: query_pool max size. Should be >= batch_size.
# QUERY_POOL_MAX_SIZE=10

# ============================================================================
# Multi-tenant configuration (Tier 2.1c)
# ============================================================================
# Per-tenant CMKs. One CMK per tenant for DEK isolation.
# DURABLE_TENANT_AWS_KMS_CMKS_JSON={"tenant_a":"alias/durable-tenant-a","tenant_b":"alias/durable-tenant-b"}
#
# Per-tenant budget caps.
# DURABLE_TENANT_BUDGET_CAPS_JSON={"tenant_a":{"max_usd":5.0}}
#
# Reserved tenant_ids (`_default`, `_legacy`) rejected at boot.
