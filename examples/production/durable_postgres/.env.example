# Copy to .env (which is .gitignored) and fill real values.
#
# PGBOUNCER WARNING (spec §7.8 / advisor #3):
#   Advisory locks are session-state. If you put pgbouncer between this
#   daemon and Postgres, it MUST run in SESSION POOLING MODE only — OR
#   the daemon must bypass it entirely with a direct DSN. Transaction or
#   statement pooling SILENTLY breaks advisory locks. You will see
#   concurrent-resume semantics break and not know why.

# DB — operator MUST supply DSN in .env (A8-H-01: compose no longer overrides).
#
# When running under docker-compose, set this with the IN-NETWORK hostname
# `postgres` AND the password from .secrets/postgres_password:
#   POSTGRES_DSN=postgresql://daemon:<password>@postgres:5432/durable
#
# For local dev outside compose, use localhost + your own DSN:
#   POSTGRES_DSN=postgresql://daemon:CHANGEME@localhost:5432/durable
#
# A8-H-01 NOTE: docker-compose previously injected an override DSN here
# without the password (compose `environment:` overrides `env_file:`),
# silently discarding the .env value. The override has been removed; the
# operator MUST set this var explicitly, matching the password in
# .secrets/postgres_password.
#
# A8-L-08: this is the SOLE source of POSTGRES_DSN at runtime. If you
# re-add an `environment.POSTGRES_DSN` entry under the `scheduler:` service
# in docker-compose.yml, that value WILL silently override this one even
# when this file has the correct password. Confirm by running:
#   docker compose exec scheduler env | grep POSTGRES_DSN
# The displayed value is what asyncpg connects with.
POSTGRES_DSN=postgresql://daemon:CHANGEME@postgres:5432/durable

# Encryption — comma-separated Fernet keys, first is encrypt-with.
# Generate a key:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Single-key deploys: one entry. Rotation: two entries during the re-encrypt
# pass (new,old). See README §"Key management" for the full procedure.
#
# F-M-02 ROTATION VERIFICATION:
#   After every config change to this variable, exec into the running daemon
#   and confirm cipher.fingerprint matches the FIRST key's first-8-hex SHA-256.
#   The daemon logs "cipher.fingerprint=<8-hex>" at startup. If the fingerprint
#   doesn't match the new key's digest, the order is swapped and rotation will
#   silently fail — old key would still be encrypt-with.
#
#   Verify:
#     docker compose exec scheduler python -c "
#       import hashlib
#       k = b'<new-key-bytes>'
#       print('expected:', hashlib.sha256(k).hexdigest()[:8])
#     "
#   Compare to the daemon's logged fingerprint.
DURABLE_CHECKPOINT_KEYS=REPLACE_WITH_FERNET_KEY

# F-H-05: namespace for advisory locks. Prevents keyspace collision with
# co-resident apps like pg_boss. Default 'durable-checkpoints' if unset;
# set to a project-unique string per deployment.
DURABLE_APP_NAMESPACE=durable-checkpoints

# Model API keys.
ANTHROPIC_API_KEY=sk-ant-REPLACE
OPENAI_API_KEY=sk-REPLACE

# Optional tuning.
MAX_CONCURRENT_RUNS=20
POLL_INTERVAL=60
MAX_TOKENS_IN=2000000
MAX_TOKENS_OUT=500000
MAX_USD=50.0

# Tier 2.1d / SCALE-1: query_pool max size. Should be >= scheduler batch_size.
# Default 10 matches batch_size=10; raise for higher batch sizes or high
# concurrency per-tenant traffic. Pool saturation queues acquire() calls.
# QUERY_POOL_MAX_SIZE=10

# ============================================================================
# Multi-tenant configuration (Tier 2.1c / D-TENANT-7 + D-TENANT-8)
# ============================================================================
#
# Single-tenant deployments: LEAVE THESE UNSET. The daemon uses the legacy
# DURABLE_CHECKPOINT_KEYS / MAX_X envs above with tenant_id="_default".
#
# Multi-tenant deployments: set BOTH below. Mismatched (cipher per-tenant
# but budget single, or vice versa) triggers a WARNING log at boot per
# Tier 2.1d / BUG-B1 audit fold-in — daemon continues but operator sees
# the asymmetric posture in the startup log.
#
# Per-tenant Fernet keys. Shape:
#   {"tenant_a": "key1,key2", "tenant_b": "key3"}
# Each key list follows the same comma-separated rotation pattern as
# DURABLE_CHECKPOINT_KEYS. Reserved tenant_ids (`_default`, `_legacy`)
# are rejected at boot per MED-1 audit fold-in.
# DURABLE_TENANT_FERNET_KEYS_JSON={"tenant_a":"REPLACE_FERNET_KEY"}
#
# Per-tenant budget caps. Shape (each tenant must have >=1 cap set;
# negative or non-numeric values rejected at boot):
#   {"tenant_a": {"max_tokens_in": 1000000, "max_usd": 5.0},
#    "tenant_b": {"max_usd": 50.0}}
# DURABLE_TENANT_BUDGET_CAPS_JSON={"tenant_a":{"max_usd":5.0}}
