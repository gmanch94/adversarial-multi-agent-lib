# Executor provider: anthropic (default) | gemini
EXECUTOR_PROVIDER=anthropic

# Anthropic (required for Anthropic executor or Anthropic reviewer)
ANTHROPIC_API_KEY=sk-ant-...

# Gemini (required if EXECUTOR_PROVIDER=gemini)
# GEMINI_API_KEY=AIza...
# GEMINI_EXECUTOR_MODEL=gemini-2.5-pro

# OpenAI (reviewer agent — cross-model adversarial pairing)
OPENAI_API_KEY=sk-...

# Optional: swap reviewer to another Claude model (same-family, less recommended)
# REVIEWER_PROVIDER=anthropic
# REVIEWER_MODEL=claude-opus-4-7

# Effort level: low | medium | high | xhigh
EFFORT_LEVEL=high

# Review convergence
MAX_REVIEW_ROUNDS=5
SCORE_THRESHOLD=8.0
